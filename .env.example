# General Application Settings
BASE_URL=https://cloudflared-issued-free-domain.trycloudflare.com   # Base URL for the application (e.g., https://app.com)
VITE_BASE_URL=cloudflared-issued-free-domain.trycloudflare.com      # Base URL for the application (e.g., https://app.com)
SERVE_FRONTEND=0                                                    # Serve FRONTEND_DIST statically from fastapi
BUILD_TARGET=development                                            # Build target for Dockerfile (development or production)
BACKEND_PORT=8000                                                   # Port for FastAPI backend
FRONTEND_PORT=5173                                                  # Port for Vite frontend development server
FRONTEND_DIST=/frontend/dist                                        # Path to the built frontend assets (used when SERVE_FRONTEND=1)

# Database          
POSTGRES_USER = secd_root                                           # PostgreSQL Root user
POSTGRES_PASSWORD = devpassword                                     # PostgreSQL Root user password
POSTGRES_APP_ROLE = secure_drive                                    # PostgreSQL role for the application
POSTGRES_APP_PASSWORD = securepassword                              # Password for the PostgreSQL role
# POSTGRES_AUDIT_READER_ROLE = secure_drive_audit_reader              # PostgreSQL role for audit querying
# POSTGRES_AUDIT_READER_PASSWORD = auditpassword                      # Password for the audit reader role
POSTGRES_HOST = postgres                                            # PostgreSQL service name in docker-compose
POSTGRES_PORT = 5432                                                # Override default PostgreSQL port if needed
POSTGRES_DB = secure_drive_database                                 # Database name for the application
POSTGRES_CONNECTIONS = 10                                           # Max number of connections for PostgreSQL
POSTGRES_LIVE_CONNECTIONS = 5                                       # Max number of connections PostgreSQL keeps open

# MinIO         
MINIO_BUCKET=objects-bucket                                         # Name of the MinIO bucket to store files (must follow a naming convention)
MINIO_HOST=minio                                                    # MinIO service name in docker-compose
MINIO_ROOT_USER=minioadmin                                          # MinIO Root user (default: minioadmin)
MINIO_ROOT_PASSWORD=your-secure-password-here                       # MinIO Root user password (default: minioadmin)
MINIO_SECURE=false                                                  # MinIO secure mode (HTTPS).
MINIO_API_PORT=9000                                                 # MinIO API port
MINIO_CONSOLE_PORT=9001                                             # MinIO Console port

# Mailer Configuration                      
SMTP_HOST=smtp.gmail.com                                            # SMTP server host (e.g., smtp.gmail.com for Gmail)
SMTP_PORT=587                                                       # SMTP server port (587 for TLS, 465 for SSL)
SMTP_ADDRESS=your-email@gmail.com                                   # Email address used as the sender for verification emails
SMTP_USERNAME=your-email-or-userid@gmail.com                        # SMTP username (usually your email address, used for authentication)
SMTP_PASSWORD="your app specific password"                          # SMTP password (use an app-specific password if using Gmail with 2FA)
SMTP_SECURITY=tls                                                   # SMTP security protocol (tls or ssl)
             
# JWT Configuration          
JWT_SECRET_KEY=A-random-32-bytes-string                             # Secret key for signing JWT tokens
# ACCESS_TOKEN_EXPIRE_MINUTES=60                                      # Access token expiration time in minutes
# REFRESH_TOKEN_EXPIRE_DAYS=30                                        # Refresh token expiration time in days
JWT_ALGORITHM=HS512                                                 # Algorithm used for JWT token encoding
